# ─── Required ────────────────────────────────────────────────
# Get your free NVIDIA NIM API key at https://build.nvidia.com/
NVIDIA_NIM_API_KEY=your_key_here
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# ─── Agent Configuration ────────────────────────────────────
MAX_AGENT_ITERATIONS=20
MAX_TOOL_TIMEOUT_SECONDS=300
AGENT_TEMPERATURE=0.1

# ─── API Server ─────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ─── Storage ────────────────────────────────────────────────
UPLOAD_DIR=./uploads
SESSION_TTL_SECONDS=3600

# ─── CTF Flag ──────────────────────────────────────────────
# Set to match your CTF's flag prefix (e.g. picoCTF, CTF, HTB)
FLAG_FORMAT=picoCTF

# ─── Optional: Pin specific NIM models per agent role ──────
# Leave empty to let the smart router auto-select.
# NIM_MODEL_SUPERVISOR=
# NIM_MODEL_CLASSIFIER=
# NIM_MODEL_WEB=
# NIM_MODEL_CRYPTO=
# NIM_MODEL_FORENSICS=
# NIM_MODEL_PWN=
# NIM_MODEL_RE=
# NIM_MODEL_MISC=
# NIM_MODEL_OSINT=
